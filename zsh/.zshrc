# --- ZSH ---
export ZSH="$HOME/.oh-my-zsh"

# --- ТЕМА ---
ZSH_THEME="aryose"

# --- ПЛАГИНЫ ---
plugins=(git zsh-syntax-highlighting zsh-autosuggestions)

source $ZSH/oh-my-zsh.sh


