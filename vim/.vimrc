" --- –Ъ–Ю–Ф–Ш–†–Ю–Т–Ъ–Р ---
set encoding=utf-8
set fileencoding=utf-8


" --- –Ю–Ґ–Ю–С–†–Р–Ц–Х–Э–Ш–Х ---
set number
set numberwidth=1
highlight LineNr ctermfg=NONE guifg=NONE
syntax on


" --- –Ґ–Р–С–£–Ы–ѓ–¶–Ш–ѓ ---
set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4
set smarttab
set smartindent


